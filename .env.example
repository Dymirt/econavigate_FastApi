# Copy this file to .env. Never commit the real token.
WARSAW_API_TOKEN=replace-with-your-warsaw-open-data-token

# Comma-separated browser origins allowed to call this API directly.
CORS_ORIGINS=http://localhost:5173,https://warsaw-moss.vercel.app

# Persistent directory: mount this path as a Docker volume in production.
CACHE_DIR=/data/cache
GREENERY_CACHE_TTL_SECONDS=604800
ROUTE_CACHE_TTL_SECONDS=600
AIR_CACHE_TTL_SECONDS=300

# Optional production settings
ENVIRONMENT=production
LOG_LEVEL=INFO
